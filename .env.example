# ==============================================================================
# mcp-server-odoo — Configuration
# ==============================================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All variables can also be passed as CLI flags (--odoo-url, --odoo-api-key, etc.)
# ==============================================================================


# ------------------------------------------------------------------------------
# ODOO_URL (required)
# ------------------------------------------------------------------------------
# Base URL of your Odoo instance. No trailing slash.
#
# Where to find it:
#   - Open your browser, navigate to your Odoo instance
#   - Copy the URL up to the domain (without /web, /web/login, etc.)
#
# Examples by hosting type:
#   - Odoo.sh:     https://mycompany.odoo.com
#   - Self-hosted: https://erp.mycompany.com
#   - Docker:      http://localhost:8069
#   - Dev server:  http://localhost:8069
#
ODOO_URL=https://your-odoo-instance.com


# ------------------------------------------------------------------------------
# ODOO_API_KEY (required)
# ------------------------------------------------------------------------------
# Bearer token for Odoo JSON/2 API authentication.
# This is NOT your login password — it's a dedicated API key.
#
# How to generate one (Odoo 17+):
#   1. Log into Odoo as the user you want the MCP server to act as
#   2. Click your avatar (top-right) → My Profile → Account Security tab
#      (or: Settings → Users & Companies → Users → your user → Account Security)
#   3. Scroll to "API Keys" section
#   4. Click "New API Key"
#   5. Name: "mcp-server" (or any descriptive name)
#   6. Scope: select "rpc" (required for JSON/2 API access)
#   7. Expiration: set a reasonable date (e.g. 90 days)
#   8. Click "Generate Key"
#   9. COPY THE KEY NOW — it is shown only once and cannot be retrieved later
#
# Security notes:
#   - The API key inherits ALL permissions of the user who created it
#   - For production, create a dedicated Odoo user with minimal access rights
#   - Restrict the user's access to only the models you need via Odoo groups
#   - Rotate keys regularly (set short expiration dates)
#   - Never commit this file with a real key to version control
#
# How to verify your key works:
#   curl -s -o /dev/null -w "%{http_code}" \
#     -X POST https://your-odoo.com/json/2/res.users/search \
#     -H "Authorization: Bearer YOUR_KEY" \
#     -H "Content-Type: application/json" \
#     -H "X-Odoo-Database: your-db" \
#     -d '{"domain": [["id","=",1]]}'
#   # Should return 200. Returns 401 if the key is invalid.
#
ODOO_API_KEY=your-api-key-here


# ------------------------------------------------------------------------------
# ODOO_DB (required)
# ------------------------------------------------------------------------------
# Name of the PostgreSQL database used by your Odoo instance.
# Sent as the X-Odoo-Database HTTP header on every request.
#
# How to find it:
#
#   Option 1 — Database manager (if accessible):
#     Navigate to https://your-odoo.com/web/database/manager
#     The database name is listed there.
#
#   Option 2 — Odoo config file:
#     Look in odoo.conf (or /etc/odoo/odoo.conf):
#       db_name = mycompany
#
#   Option 3 — PostgreSQL directly:
#     psql -l | grep odoo
#     # or: SELECT datname FROM pg_database WHERE datname NOT IN ('postgres','template0','template1');
#
#   Option 4 — Odoo.sh:
#     It's usually the project name or subdomain.
#     Check the Odoo.sh dashboard → your project → database name.
#
#   Option 5 — Docker Compose:
#     Look at the POSTGRES_DB or db_name in your docker-compose.yml.
#
# Why it matters:
#   In multi-database setups, Odoo uses this header to route the request
#   to the correct database. Even in single-database setups, the header
#   is required by the JSON/2 API.
#
ODOO_DB=your-database-name


# ------------------------------------------------------------------------------
# MODEL_INCLUDE (optional, default: *)
# ------------------------------------------------------------------------------
# Comma-separated list of glob patterns. Only models matching at least one
# pattern will be exposed as MCP tools. Default: * (all models).
#
# Uses standard glob syntax:
#   *        matches any sequence of characters (except .)
#   ?        matches any single character
#   [abc]    matches any character in the set
#
# Examples:
#   MODEL_INCLUDE=*                          # all models (default)
#   MODEL_INCLUDE=res.partner                # only res.partner
#   MODEL_INCLUDE=sale.*,purchase.*          # sales + purchasing modules
#   MODEL_INCLUDE=res.*,sale.*,account.*     # contacts + sales + accounting
#   MODEL_INCLUDE=hr.*                       # all HR models
#
# Common Odoo model prefixes:
#   res.*       — core resources (partner, users, company, currency)
#   sale.*      — sales orders, order lines, quotations
#   purchase.*  — purchase orders
#   account.*   — invoices, journal entries, payments
#   stock.*     — inventory, warehouse, pickings
#   hr.*        — employees, contracts, leave, payroll
#   project.*   — projects, tasks
#   crm.*       — leads, opportunities, pipeline
#   product.*   — products, categories, pricelists
#   mail.*      — messaging, activities
#   ir.*        — internal/system models (usually excluded)
#   bus.*       — real-time bus (usually excluded)
#
# MODEL_INCLUDE=res.*,sale.*,account.*


# ------------------------------------------------------------------------------
# MODEL_EXCLUDE (optional, default: empty)
# ------------------------------------------------------------------------------
# Comma-separated list of glob patterns. Models matching any pattern are hidden,
# even if they match MODEL_INCLUDE. Exclude always wins.
#
# Recommended exclusions for a cleaner tool list:
#   MODEL_EXCLUDE=ir.*,bus.*,base.*          # hide all internal/system models
#   MODEL_EXCLUDE=ir.logging,ir.cron,bus.*   # hide noisy internals only
#   MODEL_EXCLUDE=*.transient,*.mixin        # hide abstract/mixin models
#
# MODEL_EXCLUDE=ir.*,bus.*


# ------------------------------------------------------------------------------
# READ_ONLY (optional, default: false)
# ------------------------------------------------------------------------------
# When true, the MCP server blocks all write operations:
#   - create  → blocked
#   - write   → blocked
#   - delete  → blocked
#   - call_method → blocked (except read-only methods, see below)
#
# Read-only methods always allowed (even when READ_ONLY=true):
#   name_get, name_search, read_group, fields_get,
#   search, search_read, search_count, default_get,
#   and any method prefixed with: get_, check_, has_, is_, can_
#
# Recommended: set to true when:
#   - You want Claude to only read/explore data, not modify it
#   - You're connecting to a production database
#   - You're testing or debugging the MCP setup
#
# READ_ONLY=false


# ------------------------------------------------------------------------------
# PAGE_SIZE (optional, default: 80)
# ------------------------------------------------------------------------------
# Default number of records returned by the `search` tool when no `limit`
# parameter is provided by the caller.
#
# The search tool always returns pagination metadata:
#   { "records": [...], "total": 1234, "has_more": true, "next_offset": 80 }
#
# Guidelines:
#   - 80 is a good default for most use cases
#   - Lower (20-40) if your models have many fields or large text content
#   - Higher (200-500) if you're doing bulk exports of simple models
#   - The caller can always override this per-request via the limit parameter
#
# PAGE_SIZE=80
